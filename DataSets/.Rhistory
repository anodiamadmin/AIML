par(mar = c(4,4,2,1))
beta <- as.matrix(model_E1$beta)
log_lambda <- log(model_E1$lambda)
xg <- seq(-6, 4, length.out = 500)
matplot(xg, matrix(NA, nrow = length(xg), ncol = nrow(beta)),
type = "n",
xlab = "log(lambda)",
ylab = "Standardized Coefficients",
main = "Ridge Regression (Standardized) Coefficients vs log(lambda)",
ylim = c(-0.001, 0.005),
cex.main = 0.9, font.main = 1)
grid(col = "lightgray", lty = "dashed")
cols <- c("lightblue", "orange", "darkgreen")
for (i in 1:nrow(beta)) {
lines(log_lambda, beta[i, ], col = cols[i], lwd = 2)
}
legend("topright",
legend = rownames(beta),
col = cols,
lty = 1, lwd = 2, bty = "o")
