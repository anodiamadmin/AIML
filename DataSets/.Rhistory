# Q9 Colinearity
install.packages("car")
library(car)
vif(model_D1)
# strong linear relationship (correlation)
cor(colony_counts[, c("total.fem", "other", "total")])
# Create Model D2
model_D2 <- lm(weight ~ total.fem + other, data = colony_counts)
summary(model_D2)
