loocv_mse_ridge <- function(x, y, lambda) {
n <- nrow(x)
mse <- numeric(n)
for (i in 1:n) {
fit <- glmnet(x[-i, ], y[-i], alpha = 0, lambda = lambda)
pred <- predict(fit, newx = x[i, , drop = FALSE], s = lambda)
mse[i] <- (y[i] - pred)^2
}
mean(mse)
}
round(loocv_mse_ridge(x, y, 3), 2)
round(mean(sapply(1:nrow(x), function(i) {
fit <- glmnet(x[-i, ], y[-i], alpha = 0, lambda = 3)
(y[i] - predict(fit, newx = x[i, , drop = FALSE], s = 3))^2
})), 2)
round(max(sapply(1:nrow(x), function(i) {
fit <- glmnet(x[-i, ], y[-i], alpha = 0, lambda = 3)
(y[i] - predict(fit, newx = x[i, , drop = FALSE], s = 3))^2
})), 2)
